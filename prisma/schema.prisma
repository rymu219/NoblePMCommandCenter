// Noble PM Command Center — data model.
//
// Production DB: Postgres (Railway-managed). The DATABASE_URL env var
// drives the connection string. Local dev points at the same DB or a
// local Postgres in Docker.
//
// Enums are represented as plain string fields with the acceptable
// values documented next to each field — kept as String for now to
// minimise migration churn; can be promoted to native enums later.

generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  passwordHash String
  /// admin | engineer | viewer
  role         String   @default("viewer")
  /// engineering | process | automation | quality | scheduling | purchasing | sales | management | admin
  department   String   @default("engineering")
  /// Free-text job title, e.g. "Senior Process Engineer". Optional.
  title        String?
  /// Hourly rate in USD; null until set. Stored as float for SQLite dev.
  hourlyRate   Float?
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())

  ownedProjects ProjectRow[] @relation("OwnedProjects")
  assignments   ProjectAssignment[]
  timeEntries   TimeEntry[]
  timeNotes     TimeNote[]
  auditLog      AuditLog[]
  sessions      Session[]
  closesPerformed PeriodClose[] @relation("ClosedBy")
}

/// NextAuth-style sessions stored in DB for credentials provider.
model Session {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
}

/// Programs are derived from the prefix on each Project #.
model Program {
  prefix         String       @id // e.g. "647"
  name           String?
  customer       String?
  contactEmail   String?
  /// Free-text executive summary that opens the Executive Status Report.
  execSummary    String?
  /// Free-text "decisions needed from customer" block on the report.
  decisionsAsked String?
  createdAt      DateTime     @default(now())
  projects       ProjectRow[]
}

/// "Project" is a reserved-feel name; Prisma is happy either way. Using
/// ProjectRow to keep the relation field naming clean (`project`).
model ProjectRow {
  id                String              @id // XXX-XXX
  programPrefix     String
  program           Program             @relation(fields: [programPrefix], references: [prefix])
  name              String
  subtitle          String?
  /// not_started | active | on_hold | complete | archived
  status            String              @default("active")
  ownerId           String?
  owner             User?               @relation("OwnedProjects", fields: [ownerId], references: [id])
  startDate         DateTime?
  targetEndDate     DateTime?
  budgetTotal       Float?
  spentTotal        Float?
  committedTotal    Float?
  forecastTotal     Float?
  /// Free-text caption for the dashboard "headroom" card subline.
  headroomNote      String?
  /// Free-text qualifier for the dashboard "next trigger" line.
  nextTrigger       String?
  /// Free-text "key milestone" line on the dashboard footer strip.
  keyMilestone      String?
  /// On-track | At Risk | Off Track — used by the dashboard's hero pill.
  dashboardHealth   String?
  /// JSON: which optional sections are enabled. Stored as TEXT on SQLite.
  templateToggles   String              @default("{}")
  lastUpdatedAt     DateTime            @updatedAt
  lastUpdatedById   String?
  createdAt         DateTime            @default(now())

  sections      ProjectSection[]
  assignments   ProjectAssignment[]
  timeEntries   TimeEntry[]
  timeNotes     TimeNote[]
  ganttTasks    GanttTask[]
  meetings      Meeting[]
  attachments   Attachment[]
  statusUpdates StatusUpdate[]
  actionItems   ActionItem[]
  phases        Phase[]
  budgetTracks  BudgetTrack[]
}

/// Multi-month phase row that drives the Program Dashboard mini-Gantt.
/// Distinct from GanttTask which is week-grain for the planning Gantt.
model Phase {
  id        String     @id @default(cuid())
  projectId String
  project   ProjectRow @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name      String
  startDate DateTime
  endDate   DateTime
  /// slate | blue | purple | yellow | red — selects a fill color.
  color     String     @default("slate")
  /// Display order on the chart.
  position  Int        @default(0)
  /// Marks the current phase (label highlighted yellow on the dashboard).
  isCurrent Boolean    @default(false)

  @@index([projectId, position])
}

/// One segment of the stacked Budget Detail bar on the Program Dashboard.
model BudgetTrack {
  id        String     @id @default(cuid())
  projectId String
  project   ProjectRow @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name      String
  amount    Float
  color     String     @default("slate")
  position  Int        @default(0)

  @@index([projectId, position])
}

model ProjectAssignment {
  projectId  String
  userId     String
  project    ProjectRow @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt  DateTime   @default(now())

  @@id([projectId, userId])
}

/// One row per section instance on a project. `data` is JSON-as-TEXT.
model ProjectSection {
  id          String     @id @default(cuid())
  projectId   String
  project     ProjectRow @relation(fields: [projectId], references: [id], onDelete: Cascade)
  /// summary_cards | phases_runs | parts_material | hours_by_role |
  /// gantt_overview | gantt_detail | risks_preconditions | decisions_log |
  /// meetings | files | budget | notes_freeform
  kind        String
  position    Int
  /// JSON-encoded section data.
  data        String
  updatedAt   DateTime   @updatedAt
  updatedById String?

  @@unique([projectId, kind])
  @@index([projectId, position])
}

model GanttTask {
  id          String     @id @default(cuid())
  projectId   String
  project     ProjectRow @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name        String
  /// engineering | process | automation | quality
  role        String
  start       DateTime
  end         DateTime
  /// JSON array of GanttTask ids.
  dependsOn   String     @default("[]")
  isGate      Boolean    @default(false)
  status      String     @default("not_started")
}

model TimeEntry {
  id         String     @id @default(cuid())
  userId     String
  projectId  String
  entryDate  DateTime
  hours      Float
  source     String     @default("daily-grid")
  createdAt  DateTime   @default(now())

  user    User       @relation(fields: [userId], references: [id])
  project ProjectRow @relation(fields: [projectId], references: [id])

  @@unique([userId, projectId, entryDate])
  @@index([entryDate])
}

model TimeNote {
  id              String     @id @default(cuid())
  userId          String
  projectId       String
  weekStartDate   DateTime
  note            String

  user    User       @relation(fields: [userId], references: [id])
  project ProjectRow @relation(fields: [projectId], references: [id])

  @@unique([userId, projectId, weekStartDate])
}

model PeriodClose {
  id         String   @id @default(cuid())
  year       Int
  month      Int      // 1-12
  closedAt   DateTime @default(now())
  closedById String
  closedBy   User     @relation("ClosedBy", fields: [closedById], references: [id])

  @@unique([year, month])
}

model Meeting {
  id                          String       @id @default(cuid())
  projectId                   String
  project                     ProjectRow   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  /// agenda | transcript
  kind                        String
  occurredAt                  DateTime     @default(now())
  bodyText                    String
  agendaGeneratedFromStateAt  DateTime?
  createdById                 String?

  proposals TranscriptProposal[]
}

model TranscriptProposal {
  id              String   @id @default(cuid())
  meetingId       String
  meeting         Meeting  @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  /// matches ProjectSection.kind
  sectionKind     String
  targetId        String?  // optional row id when applicable
  /// JSON-encoded proposed change.
  proposedChange  String
  /// pending | accepted | rejected
  status          String   @default("pending")
  decidedById     String?
  decidedAt       DateTime?
}

model Attachment {
  id           String     @id @default(cuid())
  projectId    String
  project      ProjectRow @relation(fields: [projectId], references: [id], onDelete: Cascade)
  /// link | upload
  kind         String
  urlOrKey     String
  label        String
  uploadedById String?
  uploadedAt   DateTime   @default(now())
}

model AuditLog {
  id           String   @id @default(cuid())
  actorUserId  String
  actor        User     @relation(fields: [actorUserId], references: [id])
  entityType   String
  entityId     String
  action       String
  /// JSON-encoded before/after blobs.
  before       String?
  after        String?
  at           DateTime @default(now())

  @@index([entityType, entityId])
}

/// One narrative status update per project per reporting day.
/// The latest update per project is what the Daily Tooling Report renders.
model StatusUpdate {
  id               String     @id @default(cuid())
  projectId        String
  project          ProjectRow @relation(fields: [projectId], references: [id], onDelete: Cascade)
  reportDate       DateTime   // the day this status describes
  /// on_track | in_progress | at_risk | blocked | pending | complete
  statusLabel      String
  /// Free text — "Structured Delay", "External Pressure + Info Gap",
  /// "Watch Capacity", "No payment", etc.
  statusQualifier  String?
  /// JSON-encoded array of `{heading: string, body: string}`.
  blocks           String     @default("[]")
  authorId         String?
  createdAt        DateTime   @default(now())

  actionItems ActionItem[]

  @@index([projectId, reportDate])
}

/// Concrete action items grouped by owner department; populate the
/// Follow-up List in the Daily Tooling Report.
model ActionItem {
  id              String        @id @default(cuid())
  projectId       String
  project         ProjectRow    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  statusUpdateId  String?
  statusUpdate    StatusUpdate? @relation(fields: [statusUpdateId], references: [id], onDelete: SetNull)
  /// engineering | quality | process | automation | program_pm | operations |
  /// sales | purchasing | scheduling
  ownerDept       String
  ownerUserId     String?
  body            String
  dueDate         DateTime?
  completedAt     DateTime?
  createdAt       DateTime      @default(now())

  @@index([projectId, completedAt])
  @@index([ownerDept, completedAt])
}

/// Portfolio-level narrative for a specific reporting day.
/// Priority Callout / Key Risks Summary / Forward-Looking Notes.
model PortfolioNote {
  id          String   @id @default(cuid())
  reportDate  DateTime
  /// priority_callout | key_risks | forward_looking
  kind        String
  body        String
  authorId    String?
  updatedAt   DateTime @updatedAt
  createdAt   DateTime @default(now())

  @@unique([reportDate, kind])
}

/// Frozen, timestamped snapshot of a published report.
model Report {
  id             String   @id @default(cuid())
  /// daily_tooling | executive_status
  kind           String
  reportDate     DateTime
  /// null for daily (portfolio-wide); set for per-program reports.
  programPrefix  String?
  /// JSON-encoded snapshot of everything needed to re-render the report.
  snapshot       String
  publishedAt    DateTime @default(now())
  authorId       String?

  @@index([kind, reportDate])
}
