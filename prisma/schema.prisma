// Noble PM Command Center — data model.
//
// Production DB: Postgres (Railway-managed). The DATABASE_URL env var
// drives the connection string. Local dev points at the same DB or a
// local Postgres in Docker.
//
// Enums are represented as plain string fields with the acceptable
// values documented next to each field — kept as String for now to
// minimise migration churn; can be promoted to native enums later.

generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  passwordHash String
  /// admin | engineer | viewer
  role         String   @default("viewer")
  /// engineering | process | automation | quality | scheduling | purchasing | sales | management | admin
  department   String   @default("engineering")
  /// Free-text job title, e.g. "Senior Process Engineer". Optional.
  title        String?
  /// Hourly rate in USD; null until set. Stored as float for SQLite dev.
  hourlyRate   Float?
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())

  ownedProjects        ProjectRow[]          @relation("OwnedProjects")
  assignments          ProjectAssignment[]
  timeEntries          TimeEntry[]
  timeNotes            TimeNote[]
  auditLog             AuditLog[]
  sessions             Session[]
  closesPerformed      PeriodClose[]         @relation("ClosedBy")
  ownedSubtasks        Subtask[]             @relation("OwnedSubtasks")
  milestoneEngagements MilestoneEngagement[] @relation("MilestoneEngagements")
  milestoneReplans     MilestoneReplan[]     @relation("MilestoneReplans")
}

/// NextAuth-style sessions stored in DB for credentials provider.
model Session {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
}

/// Programs are derived from the prefix on each Project #.
model Program {
  prefix         String       @id // e.g. "647"
  name           String?
  customer       String?
  contactEmail   String?
  /// Free-text executive summary that opens the Executive Status Report.
  execSummary    String?
  /// Free-text "decisions needed from customer" block on the report.
  decisionsAsked String?
  createdAt      DateTime     @default(now())
  projects       ProjectRow[]
}

/// "Project" is a reserved-feel name; Prisma is happy either way. Using
/// ProjectRow to keep the relation field naming clean (`project`).
model ProjectRow {
  id              String    @id // XXX-XXX
  programPrefix   String
  program         Program   @relation(fields: [programPrefix], references: [prefix])
  name            String
  subtitle        String?
  /// pipeline | not_started | active | on_hold | complete | archived
  /// `pipeline` = prospective work being scoped; not an official project yet,
  /// excluded from rollups/status feed, flagged in Admin for setup.
  status          String    @default("active")
  ownerId         String?
  owner           User?     @relation("OwnedProjects", fields: [ownerId], references: [id])
  startDate       DateTime?
  targetEndDate   DateTime?
  budgetTotal     Float?
  spentTotal      Float?
  committedTotal  Float?
  forecastTotal   Float?
  /// Free-text caption for the dashboard "headroom" card subline.
  headroomNote    String?
  /// Free-text qualifier for the dashboard "next trigger" line.
  nextTrigger     String?
  /// Free-text "key milestone" line on the dashboard footer strip.
  keyMilestone    String?
  /// Canonical project health: on_track | at_risk | off_track. The single
  /// source of truth for every health pill/color. null is read as on_track.
  health          String?
  /// Free-form project notes (markdown-lite: **bold**, blank-line paragraphs).
  notes           String?
  /// JSON map of manufacturing-development department contacts (role→name).
  devContacts     String?
  lastUpdatedAt   DateTime  @updatedAt
  lastUpdatedById String?
  createdAt       DateTime  @default(now())

  assignments        ProjectAssignment[]
  timeEntries        TimeEntry[]
  timeNotes          TimeNote[]
  attachments        Attachment[]
  statusUpdates      StatusUpdate[]
  actionItems        ActionItem[]
  phases             Phase[]
  budgetTracks       BudgetTrack[]
  milestones         Milestone[]
  qualityInspections QualityInspection[]
  devTasks           DevTask[]
  parts              Part[]
  issues             Issue[]
  risks              Risk[]
  decisions          Decision[]
  productionRuns     ProductionRun[]
}

/// One tracked risk/precondition per row — individually editable on the
/// project page.
model Risk {
  id        String     @id @default(cuid())
  projectId String
  project   ProjectRow @relation(fields: [projectId], references: [id], onDelete: Cascade)
  body      String
  /// Free-text owner name(s) — matches existing data ("Ryan Murphy / Purchasing").
  owner     String?
  /// open | resolved
  status    String     @default("open")
  position  Int        @default(0)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@index([projectId, status, position])
}

/// One logged decision per row.
model Decision {
  id        String     @id @default(cuid())
  projectId String
  project   ProjectRow @relation(fields: [projectId], references: [id], onDelete: Cascade)
  /// When the decision was made (UTC midnight). null if the source date
  /// couldn't be parsed (the original date text is then prefixed to `body`).
  decidedOn DateTime?
  body      String
  /// meeting | unilateral
  source    String     @default("unilateral")
  author    String?
  position  Int        @default(0)
  createdAt DateTime   @default(now())

  @@index([projectId, position])
}

/// One production/material run per row.
model ProductionRun {
  id        String     @id @default(cuid())
  projectId String
  project   ProjectRow @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name      String
  purpose   String?
  parts     Int        @default(0)
  lbs       Float      @default(0)
  kg        Float      @default(0)
  position  Int        @default(0)

  @@index([projectId, position])
}

/// Multi-month phase row — drives the dashboard mini-Gantt and the v2
/// project/portfolio timelines alongside Milestone.
model Phase {
  id        String     @id @default(cuid())
  projectId String
  project   ProjectRow @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name      String
  startDate DateTime
  endDate   DateTime
  /// slate | blue | purple | yellow | red — selects a fill color.
  color     String     @default("slate")
  /// Display order on the chart.
  position  Int        @default(0)
  /// Marks the current phase (label highlighted yellow on the dashboard).
  isCurrent Boolean    @default(false)

  @@index([projectId, position])
}

/// One segment of the stacked Budget Detail bar on the Program Dashboard.
model BudgetTrack {
  id        String     @id @default(cuid())
  projectId String
  project   ProjectRow @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name      String
  amount    Float
  color     String     @default("slate")
  position  Int        @default(0)

  @@index([projectId, position])
}

model ProjectAssignment {
  projectId String
  userId    String
  project   ProjectRow @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime   @default(now())

  @@id([projectId, userId])
}

model TimeEntry {
  id        String   @id @default(cuid())
  userId    String
  projectId String
  entryDate DateTime
  hours     Float
  source    String   @default("daily-grid")
  createdAt DateTime @default(now())

  user    User       @relation(fields: [userId], references: [id])
  project ProjectRow @relation(fields: [projectId], references: [id])

  @@unique([userId, projectId, entryDate])
  @@index([entryDate])
}

model TimeNote {
  id            String   @id @default(cuid())
  userId        String
  projectId     String
  weekStartDate DateTime
  note          String

  user    User       @relation(fields: [userId], references: [id])
  project ProjectRow @relation(fields: [projectId], references: [id])

  @@unique([userId, projectId, weekStartDate])
}

model PeriodClose {
  id         String   @id @default(cuid())
  year       Int
  month      Int // 1-12
  closedAt   DateTime @default(now())
  closedById String
  closedBy   User     @relation("ClosedBy", fields: [closedById], references: [id])

  @@unique([year, month])
}

model Attachment {
  id           String     @id @default(cuid())
  projectId    String
  project      ProjectRow @relation(fields: [projectId], references: [id], onDelete: Cascade)
  /// link | upload
  kind         String
  urlOrKey     String
  label        String
  uploadedById String?
  uploadedAt   DateTime   @default(now())
}

model AuditLog {
  id          String   @id @default(cuid())
  actorUserId String
  actor       User     @relation(fields: [actorUserId], references: [id])
  entityType  String
  entityId    String
  action      String
  /// JSON-encoded before/after blobs.
  before      String?
  after       String?
  at          DateTime @default(now())

  @@index([entityType, entityId])
}

/// One narrative status update per project per reporting day.
/// The latest update per project is what the Daily Tooling Report renders.
model StatusUpdate {
  id              String     @id @default(cuid())
  projectId       String
  project         ProjectRow @relation(fields: [projectId], references: [id], onDelete: Cascade)
  reportDate      DateTime // the day this status describes
  /// on_track | in_progress | at_risk | blocked | pending | complete
  statusLabel     String
  /// Free text — "Structured Delay", "External Pressure + Info Gap",
  /// "Watch Capacity", "No payment", etc.
  statusQualifier String?
  /// v2 — markdown-lite narrative (same rules as ProjectRow.notes). One text
  /// field instead of structured blocks; replaces `blocks`.
  narrative       String?
  authorId        String?
  createdAt       DateTime   @default(now())

  actionItems ActionItem[]

  @@index([projectId, reportDate])
}

/// Concrete action items grouped by owner department; populate the
/// Follow-up List in the Daily Tooling Report.
model ActionItem {
  id             String        @id @default(cuid())
  projectId      String
  project        ProjectRow    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  statusUpdateId String?
  statusUpdate   StatusUpdate? @relation(fields: [statusUpdateId], references: [id], onDelete: SetNull)
  /// engineering | quality | process | automation | program_pm | operations |
  /// sales | purchasing | scheduling
  ownerDept      String
  ownerUserId    String?
  body           String
  dueDate        DateTime?
  completedAt    DateTime?
  createdAt      DateTime      @default(now())

  @@index([projectId, completedAt])
  @@index([ownerDept, completedAt])
}

/// Portfolio-level narrative for a specific reporting day.
/// Priority Callout / Key Risks Summary / Forward-Looking Notes.
model PortfolioNote {
  id         String   @id @default(cuid())
  reportDate DateTime
  /// priority_callout | key_risks | forward_looking
  kind       String
  body       String
  authorId   String?
  updatedAt  DateTime @updatedAt
  createdAt  DateTime @default(now())

  @@unique([reportDate, kind])
}

/// Command Center milestone — project-scoped, admin-owned, shared across all
/// engineers on the project. baselineDate freezes the ORIGINAL commitment so
/// we can measure how far the target later slipped (drift), and actualDate vs
/// baseline/target gives the "how late" evidence on the slippage report.
/// Distinct from Phase (which drives the program mini-Gantt).
model Milestone {
  id           String     @id @default(cuid())
  projectId    String
  project      ProjectRow @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title        String
  /// Free-text notes / context for the milestone. Optional.
  notes        String?
  /// Original committed target (UTC midnight). Frozen when the target is first
  /// set; only an explicit admin "re-baseline" changes it. null until dated.
  baselineDate DateTime?
  /// Current target (UTC midnight). Optional — a milestone can be jotted down
  /// before its date is known (flagged "needs a date"). Drift = target - baseline.
  targetDate   DateTime?
  /// Actual completion (UTC midnight), admin-entered from what the engineer
  /// reports. null = not yet complete. Lateness = actualDate - targetDate.
  actualDate   DateTime?
  /// Display order within the project (admin-controlled).
  position     Int        @default(0)
  /// Optional phase/group label ("Tooling", "Qualification", …). Groups
  /// milestones on the project timeline.
  phase        String?
  /// Owning department for color coding: engineering | process |
  /// automation | quality. null = unassigned (renders neutral).
  dept         String?
  createdById  String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  subtasks    Subtask[]
  engagements MilestoneEngagement[]
  replans     MilestoneReplan[]

  @@index([projectId, position])
}

/// Private (admin-only) record of every time a milestone's committed date moves:
/// a target-date "slip" or an explicit "rebaseline". Captures the REASON so the
/// Execution analytics can break down *why* dates slip. Never surfaced to
/// engineers — read only by the admin-only Execution page.
model MilestoneReplan {
  id          String    @id @default(cuid())
  milestoneId String
  milestone   Milestone @relation(fields: [milestoneId], references: [id], onDelete: Cascade)
  /// "slip" — the current target moved; "rebaseline" — the baseline was reset.
  kind        String
  /// Previous date (target for a slip, baseline for a rebaseline). null if undated.
  fromDate    DateTime?
  /// New date being committed to.
  toDate      DateTime?
  /// toDate - fromDate in whole days; positive = pushed later. 0 if either null.
  deltaDays   Int
  /// Cause category: scope | estimate | dependency | capacity | external |
  /// other | unspecified (legacy/backfilled or non-admin moves).
  reason      String
  /// Optional free-text admin context.
  note        String?
  actorUserId String
  actor       User      @relation("MilestoneReplans", fields: [actorUserId], references: [id])
  at          DateTime  @default(now())

  @@index([milestoneId])
  @@index([reason])
  @@index([at])
}

/// Engineer-owned checklist item nested under a milestone. Created/edited/
/// reordered freely by the owning engineer. Lives in exactly one engineer's
/// swimlane via ownerId.
model Subtask {
  id          String    @id @default(cuid())
  milestoneId String
  milestone   Milestone @relation(fields: [milestoneId], references: [id], onDelete: Cascade)
  /// The engineer who owns this subtask = the swimlane it appears in.
  ownerId     String
  owner       User      @relation("OwnedSubtasks", fields: [ownerId], references: [id], onDelete: Cascade)
  title       String
  /// Optional own due date (UTC midnight). null = no deadline.
  dueDate     DateTime?
  /// Completion timestamp; null = open. Non-null powers the DONE checkbox and
  /// the "+N days late" cue (completedAt - dueDate).
  completedAt DateTime?
  position    Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([milestoneId, ownerId, position])
  @@index([ownerId, completedAt])
}

/// Per-engineer override of their engagement with a milestone. ABSENCE means
/// the engineer is "direct" (the default for everyone assigned to the project);
/// a row demotes them to "supporting" — the milestone shows in their Supporting
/// section on the board rather than a date bucket.
model MilestoneEngagement {
  id          String    @id @default(cuid())
  milestoneId String
  milestone   Milestone @relation(fields: [milestoneId], references: [id], onDelete: Cascade)
  userId      String
  user        User      @relation("MilestoneEngagements", fields: [userId], references: [id], onDelete: Cascade)
  /// "support" — reserved for future tiers; a row's existence == demoted.
  role        String    @default("support")

  @@unique([milestoneId, userId])
  @@index([userId])
}

/// One task in the standardized Molded-Part Manufacturing Development process.
/// Seeded per project from DEV_CHECKLIST_TEMPLATE (lib/dev-checklist.ts). Unlike
/// Milestone (engineer/board-facing with replan history), this is the project-
/// level process tracker owned by Engineering — phase-grouped, with completion
/// and date tracking for portfolio/overdue rollups.
model DevTask {
  id             String     @id @default(cuid())
  projectId      String
  project        ProjectRow @relation(fields: [projectId], references: [id], onDelete: Cascade)
  /// Phase 1–5 (see DEV_PHASES).
  phase          Int
  /// Stable template key (e.g. "dfm1_readiness"); unique within a project.
  key            String
  label          String
  /// JSON array of assisting department codes (see DEV_DEPARTMENTS).
  departments    String     @default("[]")
  complete       Boolean    @default(false)
  /// Planned duration in whole days. Optional.
  durationDays   Int?
  /// Target/committed date (UTC midnight). Overdue = !complete && target < today.
  targetDate     DateTime?
  /// Actual completion date (UTC midnight); stamped when marked complete.
  completionDate DateTime?
  notes          String?
  position       Int        @default(0)
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  @@unique([projectId, key])
  @@index([projectId, position])
}

/// A molded part within a project — the grouping unit for the Issue Tracker.
model Part {
  id            String     @id @default(cuid())
  projectId     String
  project       ProjectRow @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name          String
  drawingNumber String?
  revision      String?
  cavities      Int?
  position      Int        @default(0)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  issues        Issue[]

  @@index([projectId, position])
}

/// One tracked issue. Content is usually imported (Claude output, pasted as
/// JSON) then triaged in-app. partId null = cross-cutting (applies to all parts).
model Issue {
  id         String           @id @default(cuid())
  projectId  String
  project    ProjectRow       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  partId     String?
  part       Part?            @relation(fields: [partId], references: [id], onDelete: SetNull)
  /// Drawing callout / characteristic number, if any.
  charLabel  String?
  title      String
  synopsis   String?
  /// open | pending | awaiting_customer | resolved
  status     String           @default("open")
  /// Owner name or role (free text — imported from the transcript).
  owner      String?
  position   Int              @default(0)
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt
  challenges IssueChallenge[]
  actions    IssueAction[]

  @@index([projectId, position])
  @@index([partId])
}

/// A named "why this is hard" block under an issue (from the report prompt).
model IssueChallenge {
  id       String @id @default(cuid())
  issueId  String
  issue    Issue  @relation(fields: [issueId], references: [id], onDelete: Cascade)
  title    String
  body     String
  position Int    @default(0)

  @@index([issueId, position])
}

/// A specific, actionable next step under an issue, with an owner + done state.
model IssueAction {
  id       String  @id @default(cuid())
  issueId  String
  issue    Issue   @relation(fields: [issueId], references: [id], onDelete: Cascade)
  body     String
  owner    String?
  done     Boolean @default(false)
  position Int     @default(0)

  @@index([issueId, position])
}

/// Frozen, timestamped snapshot of a published report.
model Report {
  id            String   @id @default(cuid())
  /// daily_tooling | executive_status
  kind          String
  reportDate    DateTime
  /// null for daily (portfolio-wide); set for per-program reports.
  programPrefix String?
  /// JSON-encoded snapshot of everything needed to re-render the report.
  snapshot      String
  publishedAt   DateTime @default(now())
  authorId      String?

  @@index([kind, reportDate])
}

/// Quality department awareness board — a GLOBAL (not project-scoped) list of
/// inspections the quality team is running, shown at the bottom of The Board.
/// Admin-populated; everyone can view. Active items (completedAt null) render in
/// the top table; marking one complete moves it to the completed archive below.
/// baselineDate freezes the first committed target so a later target move (slip)
/// can be measured; the most recent slip's standard reason + note are kept on
/// the row and carried into the completed archive (the "when & why it slipped").
model QualityInspection {
  id              String      @id @default(cuid())
  item            String
  /// Optional link to the project this inspection is for. SetNull on delete so
  /// the inspection survives if the project is removed. null = unassigned.
  projectId       String?
  project         ProjectRow? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  /// Category of work: programming | measurement | reporting | other
  category        String?
  /// Inspection method: keyence | cmm
  method          String
  /// Estimated duration in whole days. Optional.
  estDurationDays Int?
  /// Original committed target (UTC midnight), frozen when first dated. Drift =
  /// targetDate - baselineDate. null until a date is set.
  baselineDate    DateTime?
  /// Current target (UTC midnight). null = no date yet.
  targetDate      DateTime?
  /// Completion timestamp; null = active (top table), non-null = completed
  /// (bottom table). Lateness = completedAt day - targetDate.
  completedAt     DateTime?
  /// Standard reason for the most recent target move: machine | fixture | parts |
  /// priority | personnel | rework | other. null until the target first slips.
  slipReason      String?
  /// Free-text note accompanying the most recent slip.
  slipNote        String?
  /// When the most recent target move was recorded.
  slippedAt       DateTime?
  position        Int         @default(0)
  createdById     String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@index([completedAt, position])
  @@index([projectId])
}
